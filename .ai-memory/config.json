{
  "projectId": "c9bd8940ca7727d3",
  "projectName": "vemora",
  "version": "1.0.0",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "**/*.py",
    "**/*.rs",
    "**/*.go",
    "**/*.java",
    "**/*.c",
    "**/*.cpp",
    "**/*.h",
    "**/*.css",
    "**/*.scss",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml",
    "**/*.md"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/.next/**",
    "**/.nuxt/**",
    "**/coverage/**",
    "**/*.min.js",
    "**/*.bundle.js",
    ".ai-memory/**",
    ".ai-memory-cache/**"
  ],
  "maxChunkLines": 80,
  "maxChunkChars": 3000,
  "embedding": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "dimensions": 1536
  },
  "summarization": {
    "provider": "openai",
    "model": "gpt-4o-mini"
  },
  "cacheDir": "~/.ai-memory-cache/<projectId>"
}