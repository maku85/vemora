{
  "name": "vemora",
  "version": "0.1.0-alpha.5",
  "description": "Repository-local memory system for LLM-assisted development",
  "type": "commonjs",
  "author": "Maku <makuma85@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maku85/vemora.git"
  },
  "keywords": [
    "llm",
    "memory",
    "semantic search",
    "codebase",
    "rag",
    "ai",
    "typescript",
    "nodejs"
  ],
  "homepage": "https://github.com/maku85/vemora",
  "bugs": {
    "url": "https://github.com/maku85/vemora/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "bin": {
    "vemora": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node src/cli.ts",
    "clean": "rimraf dist",
    "format": "biome format --write src/",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "hnsw": "^1.1.1",
    "micromatch": "^4.0.8",
    "ora": "^5.4.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@xenova/transformers": "^2.17.2",
    "openai": "^4.67.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.21.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^20.16.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}